# Copy to .env. Never commit .env.
# This repo (gigsta-infra) orchestrates the published images.

# --- Image source (REQUIRED) ---
# GitHub owner/org that hosts the gigsta-backend & gigsta-frontend packages
GHCR_OWNER=your-github-owner
# Image tag to run (latest, or a git SHA for pinning)
TAG=latest

# --- Backend ---
DATABASE_URL=sqlite:////data/gigsta.db
SECRET_KEY=change-me-please-this-is-not-safe
ADMIN_EMAIL=admin@gigsta.app
ADMIN_PASSWORD=ChangeMe123!
ALLOWED_ORIGINS=*
TOKEN_EXPIRY_MINUTES=10080
RATE_LIMIT_PER_MINUTE=60

# --- Frontend / ports ---
HTTP_PORT=80

# --- Production HTTPS (docker-compose.prod.yml) ---
DOMAIN=gigsta.app
LE_EMAIL=you@example.com

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (optional; logs to stdout if unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Gigsta <hello@gigsta.app>

# --- Backups ---
BACKUP_KEEP_DAYS=14
